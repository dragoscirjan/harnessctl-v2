{
  "name": "harnessctl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "extensions/*"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "npx eslint \"extensions/**/*.{ts,js,mjs,cjs}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "npx prettier --check \"extensions/**/*.{ts,js,json,md,yml,yaml}\"",
    "format:fix": "npx prettier --write \"extensions/**/*.{ts,js,json,md,yml,yaml}\"",
    "dupcheck": "jscpd --config .jscpd.json",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "fallow:summary": "npx fallow --summary || true",
    "fallow:check": "npx fallow --summary --fail-on-issues",
    "fallow:audit": "npx fallow audit --base refactor",
    "fallow:dead-code": "npx fallow dead-code",
    "fallow:dupes": "npx fallow dupes",
    "fallow:health": "npx fallow health",
    "typecheck:strict": "npm run typecheck --workspaces --if-present",
    "typecheck": "npm run typecheck:strict || true",
    "quality": "npm run lint && npm run format && npm run dupcheck && npm run fallow:summary && npm run test && npm run typecheck",
    "validate": "npm run quality",
    "quality:fix": "npm run lint:fix && npm run format:fix"
  },
  "devDependencies": {
    "@jscpd/html-reporter": "^4.2.5",
    "@templ-project/eslint": "^1.3.0",
    "@templ-project/prettier": "^1.1.0",
    "@templ-project/vitest": "^0.3.2",
    "@types/node": "^22.13.10",
    "fallow": "^3.3.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.12",
    "typescript": "^5.8.2",
    "@typescript-eslint/eslint-plugin": "^8.26.0"
  },
  "prettier": "@templ-project/prettier"
}
