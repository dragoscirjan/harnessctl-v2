
# whether to run integration tests on the pre-push hook or not
RUN_INTEGRATION_TESTS_AT_PRE_PUSH=

# provider/model identifier for Pi extension integration testing
PI_TEST_MODEL=my-provider/my-model

# model endpoint for pi.dev extension integration testing
PI_TEST_BASE_URL=https://example.test/v1

# model auth key for pi.dev extension integration testing
PI_TEST_API_KEY=

# per-test timeout in milliseconds for local-model Pi integration tests
PI_TEST_TIMEOUT_MS=300000

# model to use for opencode extension integration testing
OPENCODE_TEST_MODEL=opencode/big-pickle
